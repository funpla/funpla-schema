{
  "name": "funpla-schema",
  "version": "0.0.21",
  "description": "Zod schemas and types for funpla",
  "exports": {
    "./user": {
      "import": "./dist/user.js",
      "require": "./dist/user.cjs",
      "types": "./dist/schemas/user.d.ts"
    },
    "./party": {
      "import": "./dist/party.js",
      "require": "./dist/party.cjs",
      "types": "./dist/schemas/party.d.ts"
    },
    "./plan": {
      "import": "./dist/plan.js",
      "require": "./dist/plan.cjs",
      "types": "./dist/schemas/plan.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "typesVersions": {
    "*": {
      "user": [
        "./dist/schemas/user.d.ts"
      ],
      "party": [
        "./dist/schemas/party.d.ts"
      ],
      "plan": [
        "./dist/schemas/plan.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "biome check",
    "check:write": "biome check --write",
    "prepare": "lefthook install"
  },
  "peerDependencies": {
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "^26.0.0",
    "lefthook": "^2.1.9",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "zod": "^3.23.0"
  }
}
